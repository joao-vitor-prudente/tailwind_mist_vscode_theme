  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#394447",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword.control",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#00d3f2"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00d3f2"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#ff8904"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "meta.class",
        "meta.type"
      ],
      "settings": {
        "foreground": "#ff8904"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable"
      ],
      "settings": {
        "foreground": "#a684ff"
      }
    },
    {
      "name": "Literal",
      "scope": [
        "string"
      ],
      "settings": {
        "foreground": "#00d492"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant"
      ],
      "settings": {
        "foreground": "#ff637e"
      }
    },
    {
      "name": "JSX Component",
      "scope": [
        "support.class.component"
      ],
      "settings": {
        "foreground": "#ff8904"
      }
    },
    {
      "name": "JSX HTML Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#00d3f2"
      }
    },
    {
      "name": "JSX Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#a684ff"
      }
    },
    {
      "name": "JSX Strings",
      "scope": [
        "string.quoted.double"
      ],
      "settings": {
        "foreground": "#00d492"
      }
    },
    {
      "name": "JSX Brackets",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#00d3f2"
      }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#a684ff"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#e3e7e8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold.markdown"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic.markdown"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link.markdown"
